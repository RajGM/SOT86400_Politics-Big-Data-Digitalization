  "Items": [
    {
      "ItemType": "Contribution",
      "ItemId": 38627966,
      "MemberId": 4092,
      "AttributedTo": "Stephen Metcalfe (South Basildon and East Thurrock) (Con)",
      "Value": "<Question HRSContentId=\"{E0817CEE-A081-4933-8222-56449B7D7524}\">2. <QuestionText HRSContentId=\"{35579CD4-2024-479D-8876-6E5F1F990290}\">What assessment he has made of the potential impact of AI on the functioning of the welfare system. </QuestionText></Question>",
      "OrderInSection": 1,
      "Timecode": null,
      "ExternalId": "E0817CEE-A081-4933-8222-56449B7D7524",
      "HRSTag": "Question",
      "HansardSection": "AA-AD",
      "UIN": "900001",
      "IsReiteration": false
    },
    {
      "ItemType": "Contribution",
      "ItemId": 38627967,
      "MemberId": 3935,
      "AttributedTo": "The Secretary of State for Work and Pensions (Mel Stride)",
      "Value": "We have a number of projects that use artificial intelligence within the Department to drive performance, efficiency and the service we provide to our customers. One important point to bear in mind is that we never replace a human when it comes to judgments relating to a claim or an appeal.",
      "OrderInSection": 2,
      "Timecode": null,
      "ExternalId": "0DD97389-1CFA-42F9-B744-E77C80064A42",
      "HRSTag": "hs_Para",
      "HansardSection": "AA-AD",
      "UIN": null,
      "IsReiteration": false
    },
    {
      "ItemType": "Contribution",
      "ItemId": 38627968,
      "MemberId": null,
      "AttributedTo": null,
      "Value": "<span id=\"361\" class=\"column-number column-only\" data-column-number=\"361\"></span>",
      "OrderInSection": 3,
      "Timecode": null,
      "ExternalId": null,
      "HRSTag": "hs_ColumnNumber",
      "HansardSection": null,
      "UIN": null,
      "IsReiteration": false
    },
    {
      "ItemType": "Contribution",
      "ItemId": 38627969,
      "MemberId": 4092,
      "AttributedTo": "Stephen Metcalfe",
      "Value": "Will my right hon. Friend tell the House what assessment he has made of the potential merits of the use of AI in fraud protection? How will his Department ensure that appropriate safety measures are in place?",
      "OrderInSection": 5,
      "Timecode": null,
      "ExternalId": "8FACB537-5A2A-43F8-A4CC-0671C4341C7F",
      "HRSTag": "hs_Para",
      "HansardSection": "AA-AD",
      "UIN": null,
      "IsReiteration": false
    },
    {
      "ItemType": "Contribution",
      "ItemId": 38627970,
      "MemberId": 3935,
      "AttributedTo": "Mel Stride",
      "Value": "Let me take the second of my hon. Friend’s points first. As I have outlined, there is always human intervention when it is appropriate. None the less, he is quite right to raise the issue of fraud and error. We have seen a reduction in the Department over the past year of some 10% across the benefit system, and much of that has been driven by machine learning and data analytics.",
      "OrderInSection": 6,
      "Timecode": null,
      "ExternalId": "03DCE6D9-7247-4531-B1DF-6113F793EA84",
      "HRSTag": "hs_Para",
      "HansardSection": "AA-AD",
      "UIN": null,
      "IsReiteration": false
    }
  ],
